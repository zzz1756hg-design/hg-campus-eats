// Prisma schema — 오늘 학식 말고 뭐 먹지?
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommercialArea {
  SANGDAE // 상대
  YEDAE // 예대
  GONGDAE // 공대
  HUMUN // 후문
  JEONGMUN // 정문
}

enum FoodCategory {
  KOREAN // 한식
  CHINESE // 중식
  JAPANESE // 일식
  WESTERN // 양식
  FASTFOOD // 패스트푸드
  CAFE // 카페
  ETC // 기타
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

enum EditRequestType {
  INFO_CORRECTION // 식당 정보 수정요청
  MENU_ADD // 메뉴 추가요청
  MENU_PRICE_FIX // 메뉴 가격 수정요청
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String
  name                   String
  role                   Role                    @default(USER)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  reviews                Review[]
  favorites              Favorite[]
  restaurantRequests     RestaurantRequest[]
  restaurantEditRequests RestaurantEditRequest[]
  inquiries              Inquiry[]
}

model Restaurant {
  id           String                  @id @default(cuid())
  name         String
  kakaoPlaceId String?                 @unique
  address      String
  latitude     Float
  longitude    Float
  phone        String?
  area         CommercialArea
  category     FoodCategory
  isPartnered  Boolean                 @default(false) // 학교 제휴 식당 여부
  partnershipStartDate DateTime?       // 제휴 이벤트 시작일
  partnershipEndDate   DateTime?       // 제휴 이벤트 종료일
  partnershipBenefit   String?         // 제휴 혜택 내용
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  menus        Menu[]
  reviews      Review[]
  favorites    Favorite[]
  requests     RestaurantRequest[]
  editRequests RestaurantEditRequest[]

  @@index([area])
  @@index([category])
  @@index([name])
  @@index([isPartnered])
}

model Menu {
  id           String                  @id @default(cuid())
  restaurantId String
  restaurant   Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  price        Int
  createdAt    DateTime                @default(now())
  editRequests RestaurantEditRequest[]

  @@index([restaurantId])
  @@index([name])
}

model Review {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  rating       Int // 1~5, 앱 레이어에서 검증
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, restaurantId])
  @@index([userId])
}

// 사용자가 목록에 없는 식당을 추가해달라고 제보하는 기능
model RestaurantRequest {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  address         String?
  reason          String?
  menuName        String? // 대표메뉴 이름
  menuPrice       Int? // 대표메뉴 가격
  status          RequestStatus @default(PENDING)
  rejectionReason String?
  restaurantId    String?
  restaurant      Restaurant?   @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
}

// 이미 등록된 식당의 정보/메뉴가 틀렸을 때 사용자가 수정을 요청하는 기능
model RestaurantEditRequest {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type            EditRequestType
  description     String? // 정보 수정요청의 내용(무엇이 왜 틀렸는지)
  menuId          String? // 메뉴 가격 수정요청의 대상 메뉴
  menu            Menu?           @relation(fields: [menuId], references: [id], onDelete: SetNull)
  menuName        String? // 메뉴 추가요청의 메뉴 이름 / 가격 수정요청 참고용 메뉴 이름
  menuPrice       Int? // 메뉴 추가요청의 가격 / 가격 수정요청의 제안 가격
  status          RequestStatus   @default(PENDING)
  rejectionReason String?
  createdAt       DateTime        @default(now())

  @@index([restaurantId])
  @@index([status])
}

// 1:1 문의
model Inquiry {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  content    String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}
